meta {
  name: Agent Update Limit Forbidden
  type: http
  seq: 10
}

patch {
  url: {{baseUrl}}/api/employees/{{agentId}}/trading-limit
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{agentToken}}
}

body:json {
  {
    "limit": 999999999
  }
}

tests {
  test("forbidden", function() {
    expect(res.status).to.equal(403);
  });
}
